# Peggy API — copy to .env (local) or set on host (production)

# --- Free local profile (default) ---
LLM_PROVIDER=ollama
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
NCBI_EMAIL=your@email.com

# Paid / cloud LLM (optional — leave blank for free local)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=

# --- Vector + catalog ---
QDRANT_URL=http://localhost:6333
SQLITE_DB=./data/peggy.db
# DATABASE_URL=postgresql://...  # Supabase/Neon (production)

# --- Embeddings (local, free) ---
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- PubMed (optional, higher rate limits) ---
NCBI_API_KEY=

# --- CORS (comma-separated) ---
CORS_ORIGINS=http://localhost:3000

# --- Optional: OpenAI ---
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# --- Optional: Anthropic ---
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-3-5-haiku-latest

# --- Optional: Groq (free tier, good for Vercel deploy) ---
# LLM_PROVIDER=groq
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile

# --- Optional: Upstash Redis (PubMed rate limits) ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Auth phase: Supabase (see docs/AUTH.md) ---
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_JWT_SECRET=
# SUPABASE_SERVICE_ROLE_KEY=
