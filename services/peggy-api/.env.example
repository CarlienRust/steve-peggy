# Peggy API — copy to .env (local) or set on host (production)

# --- Required for meaningful output ---
OPENAI_API_KEY=
LLM_PROVIDER=openai
OPENAI_MODEL=gpt-4o-mini
NCBI_EMAIL=your@email.com

# --- Vector + catalog ---
QDRANT_URL=http://localhost:6333
SQLITE_DB=./data/peggy.db
# DATABASE_URL=postgresql://...  # Supabase/Neon (production)

# --- Embeddings (install sentence-transformers for semantic search) ---
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- PubMed (optional, higher rate limits) ---
NCBI_API_KEY=

# --- CORS (comma-separated) ---
CORS_ORIGINS=http://localhost:3000

# --- Optional: Anthropic ---
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-3-5-haiku-latest

# --- Optional: Ollama (local) ---
# LLM_PROVIDER=ollama
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2

# --- Optional: Upstash Redis (PubMed rate limits) ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Auth phase: Supabase (see docs/AUTH.md) ---
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_JWT_SECRET=
# SUPABASE_SERVICE_ROLE_KEY=
